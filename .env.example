PORT=5000
MONGODB_URI=mongodb://localhost:27017/auth-service

# JWT configuration
# Prefer RS256 with RSA keys in production
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Fallback to HS256 only when RSA keys are missing
JWT_SECRET=change-me

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_DELAY_MS=2000
